Algoritmo "Mķdia"
// 
//  
// DescrińŃo   : Leia 10 n·meros e exiba a mķdia.
// Autor(a)    : Mķdia
// Data atual  : 30/03/2026
Var
// SeńŃo de Declarań§es das varißveis 
   vet: vetor[0..9] de inteiro
   media, soma: real
   i: inteiro
   

Inicio
   // Preenchendo o vetor
   para i de 0 ate 9 faca
        escreval("Informe um n·mero: ")
        leia(vet[i])
        soma <- soma + vet[i]
   fimpara
   //Exibindo a mķdia
   media <- soma / 10
   escreval("A mķdia ķ: ", media)


Fimalgoritmo